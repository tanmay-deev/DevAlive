# DevAlive Backend Environment Variables
# Copy this file to .env and replace the values with your own.

# Server Configuration
NODE_ENV=development
PORT=5000

# CORS Configuration (Important for security)
# For local development: http://localhost:5173
# For production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# MongoDB Connection String
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/devalive?retryWrites=true&w=majority

# JWT Authentication Secret
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=30d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Email Service Configuration (For notifications and password reset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=DevAlive Alerts <alerts@devalive.com>
